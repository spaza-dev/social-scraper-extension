{
  "manifest_version": 3,
  "name": "Spaza Social Scraper",
  "version": "1.10.0",
  "description": "Collect and scrape tweets for media monitoring and analysis",
  "permissions": ["activeTab", "storage", "sidePanel", "tabs", "alarms"],
  "host_permissions": ["https://twitter.com/*", "https://x.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["network-interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["db.js", "tweet-parser.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "action": {
    "default_title": "Tweet Scraper"
  },
  "icons": { "128": "icons/icon128.png" }
}
